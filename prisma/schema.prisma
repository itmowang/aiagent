// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  admin
  user
}

enum UserStatus {
  active
  disabled
}

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  displayName  String
  email        String?
  passwordHash String
  role         UserRole   @default(user)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  memories      Memory[]
  conversations Conversation[]
}

model Memory {
  id        String   @id @default(uuid())
  userId    String
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

// 模型配置（切换模型的核心数据源）
model ModelConfig {
  id          String   @id @default(uuid())
  name        String
  provider    String // openai / dashscope
  model       String // qwen-plus / gpt-4o
  baseUrl     String?
  apiKey      String?  @db.Text
  temperature Float    @default(0.7)
  maxTokens   Int      @default(2048)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 会话
model Conversation {
  id        String   @id @default(uuid())
  userId    String
  title     String   @default("新对话")
  modelId   String? // 该会话使用的模型（指向 ModelConfig.id）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
}

// Skill 技能（能力包：一段提示词 + 可激活的工具，由 Agent 通过 use_skill 自主调用）
model Skill {
  id           String   @id @default(uuid())
  key          String   @unique // 稳定标识，内置技能固定 key，自定义技能自动生成
  name         String
  description  String   @db.Text
  systemPrompt String   @db.Text
  toolNames    Json? // 自定义技能引用的工具名（内置技能的工具在代码里）
  builtin      Boolean  @default(false)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// MCP 服务器配置（工具来源，注册进 Agent 的工具表）
model McpServer {
  id          String   @id @default(uuid())
  name        String   @unique // 作为工具名前缀，需唯一
  transport   String // stdio / sse / http
  command     String? // stdio
  args        Json? // stdio 参数数组
  url         String? // sse / http
  enabled     Boolean  @default(true)
  autoApprove Json? // 免确认的工具名数组
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Agent 全局记忆（对所有用户、所有对话生效）
model AgentMemory {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// RAG 知识库文档（全局知识库）
model RagDocument {
  id         String   @id @default(uuid())
  filename   String
  type       String // md / txt / pdf / docx
  size       Int
  chunks     Int      @default(0)
  status     String   @default("pending") // pending / indexing / indexed / failed
  enabled    Boolean  @default(true) // 是否参与检索
  collection String
  content    String?  @db.LongText // 原始文本，用于编辑与重新索引
  error      String?  @db.Text
  vectorIds  Json? // 已写入 Qdrant 的向量 id，用于删除
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 消息
model Message {
  id             String   @id @default(uuid())
  conversationId String
  role           String // user / assistant / system / tool
  content        String   @db.Text
  toolCallId     String? // role=tool 时对应的调用 id
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}
